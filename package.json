{
  "name": "researchflow",
  "displayName": "ResearchFlow",
  "description": "AI-powered research workflow assistant",
  "version": "0.0.1",
  "publisher": "researchflow",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:researchflow.initProject",
    "onView:researchflow.projects",
    "onView:researchflow.references",
    "onView:researchflow.analysis",
    "onView:researchflow.writing",
    "onView:researchflow.storage"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "researchflow.initProject",
        "title": "ResearchFlow: Init Project",
        "icon": "$(add)"
      },
      {
        "command": "researchflow.recommendCitations",
        "title": "ResearchFlow: Recommend Citations"
      },
      {
        "command": "researchflow.draftCaption",
        "title": "ResearchFlow: Draft Caption"
      },
      {
        "command": "researchflow.openProjectDirectory",
        "title": "ResearchFlow: Open Project Directory",
        "icon": "$(folder-opened)"
      },
      {
        "command": "researchflow.selectProjectFolder",
        "title": "ResearchFlow: Select Project Folder",
        "icon": "$(folder-library)"
      },
      {
        "command": "researchflow.renameProject",
        "title": "ResearchFlow: Rename Project",
        "icon": "$(edit)"
      },
      {
        "command": "researchflow.reinitializeProject",
        "title": "ResearchFlow: Reinitialize Project",
        "icon": "$(sync)"
      },
      {
        "command": "researchflow.analysis.newFile",
        "title": "ResearchFlow: Analysis New File",
        "icon": "$(new-file)"
      },
      {
        "command": "researchflow.analysis.newFolder",
        "title": "ResearchFlow: Analysis New Folder",
        "icon": "$(new-folder)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "researchflow",
          "title": "ResearchFlow",
          "icon": "resources/researchflow.svg"
        }
      ]
    },
    "views": {
      "researchflow": [
        {
          "id": "researchflow.projects",
          "name": "Projects"
        },
        {
          "id": "researchflow.references",
          "name": "References"
        },
        {
          "id": "researchflow.analysis",
          "name": "Analysis"
        },
        {
          "id": "researchflow.writing",
          "name": "Writing"
        },
        {
          "id": "researchflow.storage",
          "name": "Storage"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "researchflow.analysis.newFile",
          "when": "view == researchflow.analysis",
          "group": "navigation@1"
        },
        {
          "command": "researchflow.analysis.newFolder",
          "when": "view == researchflow.analysis",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "researchflow.selectProjectFolder",
          "when": "view == researchflow.projects && viewItem == activeProject",
          "group": "inline"
        },
        {
          "command": "researchflow.selectProjectFolder",
          "when": "view == researchflow.projects && viewItem == activeProjectUninitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.openProjectDirectory",
          "when": "view == researchflow.projects && viewItem == activeProject",
          "group": "navigation"
        },
        {
          "command": "researchflow.openProjectDirectory",
          "when": "view == researchflow.projects && viewItem == activeProjectUninitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.reinitializeProject",
          "when": "view == researchflow.projects && viewItem == projectNameUninitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.renameProject",
          "when": "view == researchflow.projects && viewItem == projectNameInitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.reinitializeProject",
          "when": "view == researchflow.projects && viewItem == projectNameUninitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.renameProject",
          "when": "view == researchflow.projects && viewItem == projectNameInitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.analysis.newFile",
          "when": "view == researchflow.analysis && viewItem == analysisDirectory",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.newFolder",
          "when": "view == researchflow.analysis && viewItem == analysisDirectory",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.newFile",
          "when": "view == researchflow.analysis && viewItem == analysisFile",
          "group": "navigation"
        },
        {
          "command": "researchflow.analysis.newFolder",
          "when": "view == researchflow.analysis && viewItem == analysisFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
