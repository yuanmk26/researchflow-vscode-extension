{
  "name": "researchflow",
  "displayName": "ResearchFlow",
  "description": "AI-powered research workflow assistant",
  "version": "0.0.1",
  "publisher": "researchflow",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:researchflow.initProject",
    "onCommand:researchflow.analysis.openTask",
    "onCommand:researchflow.analysis.newScript",
    "onCommand:researchflow.analysis.newExperiment",
    "onCommand:researchflow.analysis.deleteExperiment",
    "onCommand:researchflow.analysis.deleteFile",
    "onCommand:researchflow.data.importData",
    "onCommand:researchflow.data.newDataFolder",
    "onCommand:researchflow.data.openDataInfo",
    "onCommand:researchflow.data.moveData",
    "onCommand:researchflow.data.deleteData",
    "onCommand:researchflow.chat.open",
    "onCommand:researchflow.chat.moveToRightSidebar",
    "onView:researchflow.projects",
    "onView:researchflow.references",
    "onView:researchflow.analysis",
    "onView:researchflow.writing",
    "onView:researchflow.data",
    "onView:researchflow.chat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "researchflow.initProject",
        "title": "ResearchFlow: Init Project",
        "icon": "$(add)"
      },
      {
        "command": "researchflow.recommendCitations",
        "title": "ResearchFlow: Recommend Citations"
      },
      {
        "command": "researchflow.draftCaption",
        "title": "ResearchFlow: Draft Caption"
      },
      {
        "command": "researchflow.openProjectDirectory",
        "title": "ResearchFlow: Open Project Directory",
        "icon": "$(folder-opened)"
      },
      {
        "command": "researchflow.selectProjectFolder",
        "title": "ResearchFlow: Select Project Folder",
        "icon": "$(folder-library)"
      },
      {
        "command": "researchflow.renameProject",
        "title": "ResearchFlow: Rename Project",
        "icon": "$(edit)"
      },
      {
        "command": "researchflow.reinitializeProject",
        "title": "ResearchFlow: Reinitialize Project",
        "icon": "$(sync)"
      },
      {
        "command": "researchflow.analysis.openTask",
        "title": "ResearchFlow: Open Analysis Task",
        "icon": "$(preview)"
      },
      {
        "command": "researchflow.analysis.newScript",
        "title": "ResearchFlow: Analysis New Script",
        "icon": "$(new-file)"
      },
      {
        "command": "researchflow.analysis.newExperiment",
        "title": "ResearchFlow: Analysis New Experiment",
        "icon": "$(beaker)"
      },
      {
        "command": "researchflow.analysis.deleteExperiment",
        "title": "ResearchFlow: Delete Analysis Experiment",
        "icon": "$(trash)"
      },
      {
        "command": "researchflow.analysis.deleteFile",
        "title": "ResearchFlow: Delete Analysis File",
        "icon": "$(trash)"
      },
      {
        "command": "researchflow.data.importData",
        "title": "ResearchFlow: Import Data",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "researchflow.data.newDataFolder",
        "title": "ResearchFlow: New Data Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "researchflow.data.openDataInfo",
        "title": "ResearchFlow: Open Data Info",
        "icon": "$(preview)"
      },
      {
        "command": "researchflow.data.moveData",
        "title": "ResearchFlow: Move Data File",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "researchflow.data.deleteData",
        "title": "ResearchFlow: Delete Data File",
        "icon": "$(trash)"
      },
      {
        "command": "researchflow.chat.open",
        "title": "ResearchFlow: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "researchflow.chat.moveToRightSidebar",
        "title": "ResearchFlow: Move Chat to Right Sidebar",
        "icon": "$(layout-sidebar-right)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "researchflow",
          "title": "ResearchFlow",
          "icon": "resources/researchflow.svg"
        }
      ],
      "panel": [
        {
          "id": "researchflow-chat",
          "title": "ResearchFlow Chat",
          "icon": "resources/researchflow.svg"
        }
      ]
    },
    "views": {
      "researchflow": [
        {
          "id": "researchflow.projects",
          "name": "Projects"
        },
        {
          "id": "researchflow.references",
          "name": "References"
        },
        {
          "id": "researchflow.analysis",
          "name": "Analysis"
        },
        {
          "id": "researchflow.writing",
          "name": "Writing"
        },
        {
          "id": "researchflow.data",
          "name": "Data"
        }
      ],
      "researchflow-chat": [
        {
          "id": "researchflow.chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "researchflow.analysis.newExperiment",
          "when": "view == researchflow.analysis",
          "group": "navigation@1"
        },
        {
          "command": "researchflow.data.importData",
          "when": "view == researchflow.data",
          "group": "navigation@1"
        },
        {
          "command": "researchflow.data.newDataFolder",
          "when": "view == researchflow.data",
          "group": "navigation@2"
        },
        {
          "command": "researchflow.chat.moveToRightSidebar",
          "when": "view == researchflow.chat",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "researchflow.selectProjectFolder",
          "when": "view == researchflow.projects && viewItem == activeProject",
          "group": "inline"
        },
        {
          "command": "researchflow.selectProjectFolder",
          "when": "view == researchflow.projects && viewItem == activeProjectUninitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.openProjectDirectory",
          "when": "view == researchflow.projects && viewItem == activeProject",
          "group": "navigation"
        },
        {
          "command": "researchflow.openProjectDirectory",
          "when": "view == researchflow.projects && viewItem == activeProjectUninitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.reinitializeProject",
          "when": "view == researchflow.projects && viewItem == projectNameUninitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.renameProject",
          "when": "view == researchflow.projects && viewItem == projectNameInitialized",
          "group": "inline"
        },
        {
          "command": "researchflow.reinitializeProject",
          "when": "view == researchflow.projects && viewItem == projectNameUninitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.renameProject",
          "when": "view == researchflow.projects && viewItem == projectNameInitialized",
          "group": "navigation"
        },
        {
          "command": "researchflow.analysis.openTask",
          "when": "view == researchflow.analysis && viewItem == analysisTask",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.newScript",
          "when": "view == researchflow.analysis && viewItem == analysisScriptsGroup",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.deleteExperiment",
          "when": "view == researchflow.analysis && viewItem == analysisTask",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.deleteFile",
          "when": "view == researchflow.analysis && viewItem == analysisStoredFile",
          "group": "inline"
        },
        {
          "command": "researchflow.analysis.newExperiment",
          "when": "view == researchflow.analysis && viewItem == analysisNewExperimentAction",
          "group": "navigation"
        },
        {
          "command": "researchflow.data.moveData",
          "when": "view == researchflow.data && viewItem == dataFile",
          "group": "navigation"
        },
        {
          "command": "researchflow.data.deleteData",
          "when": "view == researchflow.data && viewItem == dataFile",
          "group": "z_delete@99"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
